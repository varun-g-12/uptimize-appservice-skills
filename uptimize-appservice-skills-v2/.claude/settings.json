{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(az *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/validate-az.sh",
            "timeout": 30,
            "statusMessage": "Validating az command..."
          }
        ]
      }
    ]
  }
}
